-- Tương tác với hòm thư UI
local function interactWithMailUI()
    wait(1)
    
    local playerGui = player:WaitForChild("PlayerGui")
    
    -- Tìm GUI hòm thư
    local mailGui = nil
    for _, v in pairs(playerGui:GetChildren()) do
        if v:IsA("ScreenGui") then
            local name = v.Name:lower()
            if name:find("mail") or name:find("send") or name:find("gift") or name:find("thư") then
                mailGui = v
                break
            end
        end
    end
    
    if not mailGui then
        -- Thử tìm GUI đang mở
        for _, v in pairs(playerGui:GetChildren()) do
            if v:IsA("ScreenGui") and v.Enabled then
                mailGui = v
                break
            end
        end
    end
    
    if mailGui then
        -- Tìm thanh tìm kiếm ở góc phải
        local searchBox = nil
        for _, v in pairs(mailGui:GetDescendants()) do
            if v:IsA("TextBox") then
                local pos = v.AbsolutePosition
                local size = v.AbsoluteSize
                -- Kiểm tra nếu ở góc phải
                if pos.X > 500 then
                    searchBox = v
                    break
