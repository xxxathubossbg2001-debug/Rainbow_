-- Bấm nút Garden
local function clickGardenButton()
    local playerGui = player:WaitForChild("PlayerGui")
    
    for _, v in pairs(playerGui:GetDescendants()) do
        if v:IsA("ImageButton") or v:IsA("TextButton") then
            local text = v.Text:lower()
            local name = v.Name:lower()
            if text:find("garden") or name:find("garden") or text:find("vườn") or name:find("vuon") then
                local detector = v:FindFirstChildOfClass("ClickDetector")
                if detector then
                    fireclickdetector(detector)
                    return true
                end
            end
        end
    end
    
    -- Thử tìm bằng cách khác
    for _, v in pairs(playerGui:GetDescendants()) do
        if v:IsA("ImageLabel") or v:IsA("TextLabel") then
            local text = v.Text:lower()
            if text:find("garden") or text:find("vườn") then
                -- Click vào parent button
                local parent = v.Parent
                if parent:IsA("ImageButton") or parent:IsA("TextButton") then
                    local detector = parent:FindFirstChildOfClass("ClickDetector")
                    if detector then
                        fireclickdetector(detector)
                        return true
                    end
                end
            end
        end
    end
    
    return false
end

